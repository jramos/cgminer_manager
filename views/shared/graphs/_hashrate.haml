- width  = target == 'miner' ? '850' : '864'
- metric = 'hashrate'
- url    = target == 'miner' ? "#{miner_url(@miner_host_port)}/graph_data/#{metric}" : "/graph_data/#{metric}"

#hashrate-graph
  %h2 Hashrate
  %canvas(id="local_hashrate" width="#{width}" height="400")

%script
  != "window.__hashrateUrl = #{url.to_json};"
:javascript
  (function () {
    function run() {
      getJSON(window.__hashrateUrl).then(function (hash_rate_response) {
        if (!hash_rate_response || hash_rate_response.length <= 1) {
          var el = document.getElementById('hashrate-graph');
          if (el) el.remove();
          window.__chartReady && window.__chartReady();
          return;
        }
        var labels = [], hash_rates_5s = [], hash_rates_av = [];
        hash_rate_response.forEach(function (response) {
          var date = new Date(response[0] * 1000);
          if (date.getMinutes() % 5 === 0) {
            var mm = '00' + date.getMinutes().toString();
            labels.push(date.getHours() + ':' + mm.slice(-2));
          } else {
            labels.push('');
          }
          hash_rates_5s.push(response[1]);
          hash_rates_av.push(response[2]);
        });

        var canvas = document.getElementById('local_hashrate');
        var prior  = Chart.getChart(canvas); if (prior) prior.destroy();

        new Chart(canvas, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Local Hashrate',
              data: hash_rates_5s,
              backgroundColor: 'rgba(91, 183, 91, 0.35)',
              borderColor: '#5bb75b',
              fill: true,
              tension: 0.3,
              pointRadius: 2
            }]
          },
          options: {
            responsive: true,
            animation: false,
            plugins: {
              legend: { display: true },
              tooltip: { callbacks: { label: function (ctx) { return ctx.parsed.y.toFixed(2) + ' GH/s'; } } }
            }
          }
        });

        injectHashrateTable(hash_rates_5s, hash_rates_av, [], '#hashrate-graph');
        window.__chartReady && window.__chartReady();
      }).catch(function () {
        window.__chartReady && window.__chartReady();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();

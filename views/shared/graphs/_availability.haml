- width  = target == 'miner' ? '850' : '864'
- metric = 'availability'
- url    = target == 'miner' ? "#{miner_url(@miner_host_port)}/graph_data/#{metric}" : "/graph_data/#{metric}"

#availability-graph
  %h2 Availability
  %canvas(id="local_availability" width="#{width}" height="400")

%script
  != "window.__availabilityUrl = #{url.to_json}; window.__availabilityIsMiner = #{(target == 'miner').to_json};"
:javascript
  (function () {
    function run() {
      var isMiner = window.__availabilityIsMiner;
      getJSON(window.__availabilityUrl).then(function (response_data) {
        if (!response_data || response_data.length <= 1) {
          var el = document.getElementById('availability-graph');
          if (el) el.remove();
          window.__chartReady && window.__chartReady();
          return;
        }
        var labels = [], availabilities = [];
        response_data.forEach(function (response) {
          var date = new Date(response[0] * 1000);
          if (date.getMinutes() % 5 === 0) {
            var mm = '00' + date.getMinutes().toString();
            labels.push(date.getHours() + ':' + mm.slice(-2));
          } else {
            labels.push('');
          }
          availabilities.push(isMiner ? response[1] * 100 : response[1] / parseFloat(response[2]) * 100);
        });

        var canvas = document.getElementById('local_availability');
        var prior  = Chart.getChart(canvas); if (prior) prior.destroy();

        new Chart(canvas, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Local Availability',
              data: availabilities,
              backgroundColor: 'rgba(91, 183, 91, 0.35)',
              borderColor: '#5bb75b',
              fill: true,
              tension: 0.3,
              pointRadius: 2
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            plugins: {
              legend: { display: true },
              tooltip: { callbacks: { label: function (ctx) { return ctx.parsed.y.toFixed(2) + ' %'; } } }
            },
            scales: { y: { beginAtZero: true } }
          }
        });

        injectAvailabilityTable(availabilities, '#availability-graph');
        window.__chartReady && window.__chartReady();
      }).catch(function () {
        window.__chartReady && window.__chartReady();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();

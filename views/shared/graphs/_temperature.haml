- width  = target == 'miner' ? '850' : '864'
- metric = 'temperature'
- url    = target == 'miner' ? "#{miner_url(@miner_host_port)}/graph_data/#{metric}" : "/graph_data/#{metric}"

#temperature-graph
  %h2 Temperature
  %canvas(id="local_temperature" width="#{width}" height="400")

%script
  != "window.__temperatureUrl = #{url.to_json};"
:javascript
  (function () {
    function run() {
      getJSON(window.__temperatureUrl).then(function (temperature_response) {
        if (!temperature_response || temperature_response.length <= 1) {
          var el = document.getElementById('temperature-graph');
          if (el) el.remove();
          window.__chartReady && window.__chartReady();
          return;
        }
        var labels = [], min_temperatures = [], avg_temperatures = [], max_temperatures = [];
        temperature_response.forEach(function (response) {
          var date = new Date(response[0] * 1000);
          if (date.getMinutes() % 5 === 0) {
            var mm = '00' + date.getMinutes().toString();
            labels.push(date.getHours() + ':' + mm.slice(-2));
          } else {
            labels.push('');
          }
          min_temperatures.push(response[1]);
          avg_temperatures.push(response[2]);
          max_temperatures.push(response[3]);
        });

        var canvas = document.getElementById('local_temperature');
        var prior  = Chart.getChart(canvas); if (prior) prior.destroy();

        new Chart(canvas, {
          type: 'line',
          data: {
            labels: labels,
            // Max fills down to Min (fill: '+2' points two datasets ahead)
            // so the shaded area is the Max..Min range band. Avg is drawn as
            // a line through the band; Min has no fill below it.
            datasets: [
              { label: 'Max Temperature', data: max_temperatures,
                backgroundColor: 'rgba(255, 0, 0, 0.15)', borderColor: 'red',     fill: '+2', tension: 0.3, pointRadius: 2 },
              { label: 'Avg Temperature', data: avg_temperatures,
                backgroundColor: 'orange',                borderColor: 'orange',  fill: false, tension: 0.3, pointRadius: 2 },
              { label: 'Min Temperature', data: min_temperatures,
                backgroundColor: '#d4b400',               borderColor: '#d4b400', fill: false, tension: 0.3, pointRadius: 2 }
            ]
          },
          options: {
            responsive: true,
            animation: false,
            plugins: {
              legend: { display: true },
              tooltip: { callbacks: { label: function (ctx) { return ctx.parsed.y.toFixed(2) + ' C'; } } }
            }
          }
        });

        injectTemperatureTable(min_temperatures, avg_temperatures, max_temperatures, '#temperature-graph');
        window.__chartReady && window.__chartReady();
      }).catch(function () {
        window.__chartReady && window.__chartReady();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();

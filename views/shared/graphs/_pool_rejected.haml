- width  = target == 'miner' ? '850' : '864'
- metric = 'hashrate'
- url    = target == 'miner' ? "#{miner_url(@miner_host_port)}/graph_data/#{metric}" : "/graph_data/#{metric}"

#pool-rejected-hashrate-graph
  %h2 Pool Rejected %
  %canvas(id="pool_rejected_hashrate" width="#{width}" height="400")

%script
  != "window.__poolRejectedUrl = #{url.to_json};"
:javascript
  (function () {
    function run() {
      getJSON(window.__poolRejectedUrl).then(function (hash_rate_response) {
        if (!hash_rate_response || hash_rate_response.length <= 1) {
          var el = document.getElementById('pool-rejected-hashrate-graph');
          if (el) el.remove();
          window.__chartReady && window.__chartReady();
          return;
        }
        var labels = [], error_rates = [], error_rates_raw = [];
        hash_rate_response.forEach(function (response) {
          var date = new Date(response[0] * 1000);
          if (date.getMinutes() % 5 === 0) {
            var mm = '00' + date.getMinutes().toString();
            labels.push(date.getHours() + ':' + mm.slice(-2));
          } else {
            labels.push('');
          }
          error_rates.push(response[5] * 100);
          error_rates_raw.push(response[5]);
        });

        var canvas = document.getElementById('pool_rejected_hashrate');
        var prior  = Chart.getChart(canvas); if (prior) prior.destroy();

        new Chart(canvas, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [{
              label: 'Pool Rejected',
              data: error_rates,
              backgroundColor: 'rgba(255, 165, 0, 0.25)',
              borderColor: 'orange',
              fill: true,
              tension: 0.3,
              pointRadius: 2
            }]
          },
          options: {
            responsive: true,
            animation: false,
            plugins: {
              legend: { display: true },
              tooltip: { callbacks: { label: function (ctx) { return ctx.parsed.y + '%'; } } }
            }
          }
        });

        injectHashrateTable([], [], error_rates_raw, '#pool-rejected-hashrate-graph');
        window.__chartReady && window.__chartReady();
      }).catch(function () {
        window.__chartReady && window.__chartReady();
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();

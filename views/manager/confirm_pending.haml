!!!
%html
  %head
    %meta{ charset: 'utf-8' }
    %meta{ name: 'viewport', content: 'width=device-width, initial-scale=1' }
    %meta{ name: 'csrf-token', content: Rack::Protection::AuthenticityToken.token(session) }
    %title Confirm action
    :css
      body { font-family: system-ui, -apple-system, sans-serif; padding: 2rem; max-width: 40rem; margin: 0 auto; }
      .pending { background: #fff8e1; border: 1px solid #f0c040; border-radius: 0.25rem; padding: 1.5rem; }
      .pending h1 { margin-top: 0; font-size: 1.25rem; }
      .pending dl { display: grid; grid-template-columns: max-content 1fr; gap: 0.25rem 1rem; margin: 1rem 0; }
      .pending dt { font-weight: 600; }
      .actions { display: flex; gap: 0.75rem; margin-top: 1rem; }
      .actions button { padding: 0.5rem 1rem; border-radius: 0.25rem; border: 1px solid #ccc; cursor: pointer; }
      .actions button.confirm { background: #c00; color: white; border-color: #900; }
      .actions button.cancel { background: #f4f4f4; }
  %body
    .pending
      %h1 Confirm action
      %p
        This action is destructive and requires confirmation within
        %strong 2 minutes
        \. The pending request will not execute until you click
        %strong Confirm
        below.
      %dl
        %dt Command
        %dd= h(@pending_entry.command)
        %dt Scope
        %dd= h(@pending_entry.scope)
        %dt Token expires
        %dd= h(@pending_entry.expires_at.iso8601(0))
      .actions
        %form{ action: "/manager/admin/confirm/#{h(@pending_entry.token)}", method: 'post' }
          %input{ type: 'hidden', name: 'authenticity_token', value: Rack::Protection::AuthenticityToken.token(session) }
          %button.confirm{ type: 'submit' } Confirm
        %form{ action: "/manager/admin/confirm/#{h(@pending_entry.token)}", method: 'post' }
          %input{ type: 'hidden', name: '_method', value: 'delete' }
          %input{ type: 'hidden', name: 'authenticity_token', value: Rack::Protection::AuthenticityToken.token(session) }
          %button.cancel{ type: 'submit' } Cancel

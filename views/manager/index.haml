- if @view[:banner]
  .alert.alert-warning= @view[:banner]

#manager
  #manager-content
    %ul
      %li!= link_to('Summary', '#summary')
      %li!= link_to('Miner Pool', '#miner-pool')
      %li!= link_to('Admin', '#admin', class: 'danger')

    != render_partial 'manager/summary'
    != render_partial 'manager/miner_pool'
    != render_partial 'manager/admin'

  :javascript
    // Defer initTabs until every graph partial has rendered so the
    // availability canvas on the Miner Pool panel gets laid out at full
    // width before that panel is hidden.
    window.__chartsReadyPromise.then(function () {
      initTabs('#manager-content', { activate: setWindowHash });
    });

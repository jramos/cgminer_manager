#miner-show
  #prev-next-miner
    - if @prev_miner_url
      .left!= link_to(raw("&laquo; Previous Miner"), @prev_miner_url)
    - if @next_miner_url
      .right!= link_to(raw("Next Miner &raquo;"), @next_miner_url)
    .clear

  - unless @miner.nil? || !@miner.available?
    - content_for(:page_title) do
      != link_to("CgminerManager", root_url) + ' > ' + @miner.to_s

    != render_partial 'shared/warnings'

    .clear

    #miner
      #tabs
        %ul
          %li!= link_to('Miner', '#summary')
          %li!= link_to('Devs',  '#devices')
          %li!= link_to('Pools', '#pools')
          %li!= link_to('Stats', '#stats')
          %li!= link_to('Admin', '#admin', class: 'danger')

        != render_partial 'miner/summary'
        != render_partial 'miner/devices'
        != render_partial 'miner/pools'
        != render_partial 'miner/stats'
        != render_partial 'miner/admin'

    %script
      != "window.__minerUrl = #{@miner_url.to_json};"
    :javascript
      document.removeEventListener('update', window.__minerShowUpdate);

      window.__minerShowUpdate = function () {
        if (window.__minerShowAbort) window.__minerShowAbort.abort();
        window.__minerShowAbort = new AbortController();

        if (typeof window.__resetChartsReady === 'function') {
          window.__resetChartsReady();
        }

        var updated = document.getElementById('updated');
        if (updated) { updated.classList.add('updating'); updated.textContent = 'Updating...'; }
        document.title = 'Updating...';

        csrfFetch(window.__minerUrl, { signal: window.__minerShowAbort.signal })
          .then(function (r) { return r.text(); })
          .then(function (html) {
            var doc      = new DOMParser().parseFromString(html, 'text/html');
            var incoming = doc.getElementById('miner-show');
            var current  = document.getElementById('miner-show');
            if (!incoming || !current) return;
            current.innerHTML = incoming.innerHTML;

            // DOMParser <script> nodes don't execute. Clone each so graph
            // partials and nested-tab inits run again.
            var scripts = current.querySelectorAll('script');
            for (var i = 0; i < scripts.length; i++) {
              var old = scripts[i];
              var neu = document.createElement('script');
              for (var j = 0; j < old.attributes.length; j++) {
                neu.setAttribute(old.attributes[j].name, old.attributes[j].value);
              }
              neu.text = old.textContent;
              old.parentNode.replaceChild(neu, old);
            }

            var freshUpdated = document.getElementById('updated');
            if (freshUpdated) {
              freshUpdated.classList.remove('updating');
              freshUpdated.innerHTML = '<b>Updated:</b> <span>' + new Date().toLocaleTimeString() + '</span>';
            }
            document.title = 'CgminerManager';
          })
          .catch(function (e) {
            if (e && e.name === 'AbortError') return;
            var freshUpdated = document.getElementById('updated');
            if (freshUpdated) { freshUpdated.classList.remove('updating'); freshUpdated.textContent = 'Update failed'; }
            document.title = 'CgminerManager';
          });
      };
      document.addEventListener('update', window.__minerShowUpdate);

  - else
    #miner
      #tabs
        %ul
          %li!= link_to('Summary', '#summary')

      #summary
        #unknown-unavailable
          - if @miner.nil?
            Unknown miner
          - else
            Miner unavailable

:javascript
  $(function() {
    $('#tabs').tabs({activate: setWindowHash});
  });

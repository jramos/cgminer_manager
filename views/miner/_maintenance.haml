- schedule  = @maintenance_schedule
- enabled   = schedule&.enabled
- time_utc  = schedule&.time_utc
- last_at   = schedule&.last_restart_at

#maintenance.maintenance-section
  %h3 Scheduled Restart
  %p.muted
    Restart this miner once per day at the chosen UTC time. Skipped silently
    if the miner is offline or the restart RPC fails (see logs).

  %form.admin-form{ action: "#{miner_url(@miner_host_port)}/maintenance", method: 'post', 'data-target' => '#maintenance' }
    %input{ type: 'hidden', name: 'authenticity_token', value: csrf_token }
    %label
      %input{ type: 'checkbox', name: 'enabled', value: '1', checked: enabled }
      Enable scheduled restart
    %label
      Time (UTC, HH:MM)
      %input{ type: 'text', name: 'time_utc', value: time_utc, maxlength: '5', pattern: '([01][0-9]|2[0-3]):[0-5][0-9]', placeholder: '04:00' }
    %button{ type: 'submit' } Save

  %p.muted
    %strong Last restart:
    - if last_at && !last_at.empty?
      = last_at
    - else
      &mdash;

  - if @maintenance_error_msg && !@maintenance_error_msg.empty?
    %p.danger= @maintenance_error_msg
